<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.PostesController">

    <top>
        <HBox styleClass="toolbar" spacing="8" alignment="CENTER_LEFT">
            <Label text="Postes" styleClass="view-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnAdd"     text="+ Ajouter"  onAction="#onAdd"     styleClass="btn-primary"/>
            <Button fx:id="btnEdit"    text="Modifier"   onAction="#onEdit"    styleClass="btn-secondary"/>
            <Button fx:id="btnDelete"  text="Supprimer"  onAction="#onDelete"  styleClass="btn-danger"/>
            <Button fx:id="btnRefresh" text="Actualiser" onAction="#onRefresh" styleClass="btn-secondary"/>
        </HBox>
    </top>

    <center>
        <TableView fx:id="table" BorderPane.alignment="CENTER">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colIntitule"    text="Intitulé du poste"  prefWidth="220"/>
                <TableColumn fx:id="colDepartement" text="Département"        prefWidth="180"/>
                <TableColumn fx:id="colGrade"       text="Grade"              prefWidth="160"/>
                <TableColumn fx:id="colMode"        text="Mode de travail"    prefWidth="130"/>
                <TableColumn fx:id="colContrat"     text="Type de contrat"    prefWidth="120"/>
            </columns>
        </TableView>
    </center>

</BorderPane>

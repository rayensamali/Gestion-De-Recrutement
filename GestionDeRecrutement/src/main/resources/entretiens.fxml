<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.EntretiensController">

    <top>
        <HBox styleClass="toolbar" spacing="8" alignment="CENTER_LEFT">
            <Label text="Entretiens" styleClass="view-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnAdd"     text="+ Planifier"  onAction="#onAdd"     styleClass="btn-primary"/>
            <Button fx:id="btnEdit"    text="Modifier"     onAction="#onEdit"    styleClass="btn-secondary"/>
            <Button fx:id="btnDelete"  text="Supprimer"    onAction="#onDelete"  styleClass="btn-danger"/>
            <Button fx:id="btnRefresh" text="Actualiser"   onAction="#onRefresh" styleClass="btn-secondary"/>
        </HBox>
    </top>

    <center>
        <TableView fx:id="table" BorderPane.alignment="CENTER">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colCode"    text="Code"         prefWidth="110"/>
                <TableColumn fx:id="colCandidat" text="Candidat"    prefWidth="160"/>
                <TableColumn fx:id="colType"    text="Type"         prefWidth="100"/>
                <TableColumn fx:id="colStatut"  text="Statut"       prefWidth="100"/>
                <TableColumn fx:id="colDate"    text="Date"         prefWidth="100"/>
                <TableColumn fx:id="colDebut"   text="Début"        prefWidth="80"/>
                <TableColumn fx:id="colFin"     text="Fin"          prefWidth="80"/>
                <TableColumn fx:id="colDuree"   text="Durée (min)"  prefWidth="90"/>
            </columns>
        </TableView>
    </center>

</BorderPane>

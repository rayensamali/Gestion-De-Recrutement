<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.RecruteursController">

    <top>
        <HBox styleClass="toolbar" spacing="8" alignment="CENTER_LEFT">
            <Label text="Recruteurs" styleClass="view-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnAdd"     text="+ Ajouter"  onAction="#onAdd"     styleClass="btn-primary"/>
            <Button fx:id="btnEdit"    text="Modifier"   onAction="#onEdit"    styleClass="btn-secondary"/>
            <Button fx:id="btnDelete"  text="Supprimer"  onAction="#onDelete"  styleClass="btn-danger"/>
            <Button fx:id="btnRefresh" text="Actualiser" onAction="#onRefresh" styleClass="btn-secondary"/>
        </HBox>
    </top>

    <center>
        <TableView fx:id="table" BorderPane.alignment="CENTER">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colNom"   text="Nom complet" prefWidth="250"/>
                <TableColumn fx:id="colEmail" text="Email"       prefWidth="280"/>
                <TableColumn fx:id="colRole"  text="Rôle"        prefWidth="150"/>
            </columns>
        </TableView>
    </center>

</BorderPane>

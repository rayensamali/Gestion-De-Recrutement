<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.CandidaturesController">

    <top>
        <HBox styleClass="toolbar" spacing="8" alignment="CENTER_LEFT">
            <Label text="Candidatures" styleClass="view-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnAdd"     text="+ Ajouter"  onAction="#onAdd"     styleClass="btn-primary"/>
            <Button fx:id="btnEdit"    text="Modifier"   onAction="#onEdit"    styleClass="btn-secondary"/>
            <Button fx:id="btnDelete"  text="Supprimer"  onAction="#onDelete"  styleClass="btn-danger"/>
            <Button fx:id="btnRefresh" text="Actualiser" onAction="#onRefresh" styleClass="btn-secondary"/>
            <Button fx:id="btnQRCode"  text="QR Code"   onAction="#onQRCode"  styleClass="btn-secondary"/>
        </HBox>
    </top>

    <center>
        <TableView fx:id="table" BorderPane.alignment="CENTER">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colCode"         text="Code"           prefWidth="110"/>
                <TableColumn fx:id="colCandidat"     text="Candidat"       prefWidth="170"/>
                <TableColumn fx:id="colPoste"        text="Poste"          prefWidth="170"/>
                <TableColumn fx:id="colPhase"        text="Phase"          prefWidth="150"/>
                <TableColumn fx:id="colDecision"     text="Décision"       prefWidth="110"/>
                <TableColumn fx:id="colDateCand"     text="Date candidature" prefWidth="120"/>
                <TableColumn fx:id="colDateDecision" text="Date décision"  prefWidth="120"/>
            </columns>
        </TableView>
    </center>

</BorderPane>
